<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Sketch &amp; Snack - Home</title>
<!-- Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,700;0,800;1,800&amp;family=Be+Vietnam+Pro:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "primary": "#FF8C42",
              "on-primary": "#ffffff",
              "primary-container": "#FFDCC7",
              "on-primary-container": "#451b00",
              "surface": "#f6f6f6",
              "on-surface": "#2d2f2f",
              "on-surface-variant": "#5a5c5c",
              "surface-container": "#e7e8e8",
              "surface-container-high": "#e1e3e3",
              "surface-container-low": "#f0f1f1",
              "outline": "#767777",
            },
            fontFamily: {
              "headline": ["Plus Jakarta Sans"],
              "body": ["Be Vietnam Pro"],
              "label": ["Be Vietnam Pro"]
            },
            borderRadius: {"DEFAULT": "0.5rem", "lg": "0.75rem", "xl": "1rem", "full": "9999px"},
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .active-icon {
            font-variation-settings: 'FILL' 1;
        }
        body {
            min-height: 100dvh;
            overflow-x: hidden;
        }
        .nav-rail {
            top: 50%;
            transform: translateY(-50%);
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .nav-item {
            position: relative;
            z-index: 10;
            transition: transform 0.4s ease, opacity 0.4s ease;
        }

        #nav-indicator {
            position: absolute;
            width: 48px;
            height: 48px;
            background-color: rgba(255, 140, 66, 0.2);
            border-radius: 12px;
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            z-index: 0;
            pointer-events: none;
        }

        /* AI Transition Styles */
        body.ai-active {
            overflow: hidden;
        }

        .ai-active aside.nav-rail {
            width: 280px;
            left: 24px;
            border-radius: 2rem;
            height: 80vh;
            padding: 0;
            overflow: hidden;
        }

        .ai-active #nav-indicator {
            width: 100% !important;
            height: 100% !important;
            top: 0 !important;
            left: 0 !important;
            border-radius: 2rem;
            opacity: 1;
            background-color: #FF8C42;
        }

        .ai-active .nav-item {
            transform: translateY(100px);
            opacity: 0;
            pointer-events: none;
        }

        .history-content {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease 0.3s;
            z-index: 20;
            color: white;
            display: flex;
            flex-direction: column;
        }

        .ai-active .history-content {
            opacity: 1;
            pointer-events: auto;
        }

        .ai-input-wrapper {
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .ai-active .ai-input-wrapper {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 380px); /* Adjust for sidebar */
            z-index: 100;
            max-width: 800px;
        }

        .recommendation-cards {
            transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
        }

        .ai-active .recommendation-cards {
            transform: translateY(100vh);
            opacity: 0;
        }

        .hero-header {
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            transform-origin: left top;
        }

        .ai-active .hero-header {
            transform: translateY(20px) scale(0.6);
            opacity: 0;
        }

        .chat-container {
            position: fixed;
            top: 100px;
            left: 320px;
            right: 40px;
            bottom: 140px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease 0.4s;
            overflow-y: auto;
            padding-right: 20px;
        }

        .ai-active .chat-container {
            opacity: 1;
            pointer-events: auto;
        }

        .ai-orb-glow {
            box-shadow: 0 0 20px rgba(255, 140, 66, 0.3);
            animation: pulse 3s infinite ease-in-out;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
        }

        @keyframes magical-flow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .ai-input-glow-wrapper {
            position: relative;
            padding: 3px;
            border-radius: 9999px;
            transition: all 0.3s ease;
        }
        .ai-input-glow-wrapper:hover, .ai-active .ai-input-glow-wrapper {
            background: linear-gradient(90deg, #FF8C42, #FFDCC7, #ff3d00, #FF8C42);
            background-size: 300% 300%;
            animation: magical-flow 2s linear infinite;
            box-shadow: 0 0 20px rgba(255, 140, 66, 0.4);
        }
    </style>
</head>
<body class="bg-[#fbfbfb] text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
<!-- Top App Bar -->
<header class="fixed top-0 left-0 right-0 h-20 flex items-center justify-between px-8 z-50 bg-[#fbfbfb]/80 backdrop-blur-md">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-primary cursor-pointer text-2xl">menu</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 32px;">restaurant</span>
<h1 class="font-headline font-black text-2xl tracking-tight text-primary italic">CampusBite</h1>
</div>
<div class="flex items-center gap-4">
<button class="w-11 h-11 flex items-center justify-center rounded-full hover:bg-surface-container transition-colors">
<span class="material-symbols-outlined text-on-surface-variant text-2xl">search</span>
</button>
<div class="w-11 h-11 rounded-full bg-surface-container-high overflow-hidden border-2 border-white shadow-sm cursor-pointer">
<img alt="User Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCyXa7VhjGAgaSrDF4m0zcosGWc6e02Buna51pel2wDasjtvGisB_5S-iSKgZCjVMtbstTOyqKdegp21_stHVha68--f_rRwFrxQ2sxftKLVnuNATBXL_WoESDE5qqPda_TXXy-MnZgm6ol-QTPN7Y7CKDBdjn8vaqk9bYhQSzd6YBgxLhwTWp3fXtQ4b4kimJ4p-pPKWjTV-NVtVq7o4ftm-_SB5LA4GIjnwOPK_GPQ1DnhnpARhNZnBz0CEHSc8rOM2O9l8gbiw"/>
</div>
</div>
</header>
<!-- Floating Navigation Rail -->
<aside class="fixed left-6 nav-rail hidden md:flex flex-col items-center z-40 w-20 bg-white/90 backdrop-blur-md rounded-full shadow-2xl border border-gray-100/50 py-10 h-auto">
<div id="nav-indicator"></div>
<nav class="flex flex-col gap-12 w-full items-center relative h-full">
<!-- Home -->
<a class="nav-item flex flex-col items-center gap-2 group active" data-id="home" href="#" onclick="switchTab('home', this)">
<div class="icon-box w-12 h-12 flex items-center justify-center transition-all">
<span class="material-symbols-outlined text-2xl text-primary active-icon">home</span>
</div>
<span class="label font-headline font-bold text-[10px] uppercase tracking-wider text-primary">Home</span>
</a>
<!-- Restaurants -->
<a class="nav-item flex flex-col items-center gap-2 group" data-id="restaurants" href="#" onclick="switchTab('restaurants', this)">
<div class="icon-box w-12 h-12 flex items-center justify-center transition-all">
<span class="material-symbols-outlined text-2xl text-on-surface-variant">restaurant</span>
</div>
<span class="label font-headline font-bold text-[10px] uppercase tracking-wider text-on-surface-variant">Rest</span>
</a>
<!-- Post -->
<a class="nav-item flex flex-col items-center gap-2 group" data-id="post" href="#" onclick="switchTab('post', this)">
<div class="icon-box w-12 h-12 flex items-center justify-center transition-all">
<span class="material-symbols-outlined text-2xl text-on-surface-variant">add_box</span>
</div>
<span class="label font-headline font-bold text-[10px] text-on-surface-variant uppercase tracking-wider">Post</span>
</a>
<!-- Map -->
<a class="nav-item flex flex-col items-center gap-2 group" data-id="map" href="#" onclick="goToMap()">
<div class="icon-box w-12 h-12 flex items-center justify-center transition-all">
<span class="material-symbols-outlined text-2xl text-on-surface-variant">map</span>
</div>
<span class="label font-headline font-bold text-[10px] text-on-surface-variant uppercase tracking-wider">Map</span>
</a>
<!-- Profile -->
<a class="nav-item flex flex-col items-center gap-2 group" data-id="profile" href="#" onclick="switchTab('profile', this)">
<div class="icon-box w-12 h-12 flex items-center justify-center transition-all">
<span class="material-symbols-outlined text-2xl text-on-surface-variant">person</span>
</div>
<span class="label font-headline font-bold text-[10px] text-on-surface-variant uppercase tracking-wider">Profile</span>
</a>
<!-- Transformation Overlay: History Sidebar Content -->
<div class="history-content flex flex-col w-full h-full">
<button class="p-8 flex items-center gap-4 border-b border-white/20 hover:bg-white/10 transition-colors group" onclick="toggleAI(false)">
<span class="material-symbols-outlined text-3xl transition-transform group-hover:-translate-x-1">arrow_back</span>
<span class="font-headline font-bold tracking-tight text-lg">Go Back</span>
</button>
<div class="flex-grow p-6 flex flex-col gap-6 overflow-y-auto">
<p class="font-headline font-bold text-xs uppercase tracking-[0.2em] opacity-60 mb-2">History</p>
<div class="p-4 rounded-xl bg-white/10 border border-white/10 cursor-pointer hover:bg-white/20 transition-all">
<p class="text-[10px] font-bold opacity-70 mb-1">TODAY • 12:30 PM</p>
<p class="font-body text-sm line-clamp-2">"I want something spicy near the Library..."</p>
</div>
<div class="p-4 rounded-xl bg-white/5 border border-white/5 cursor-pointer hover:bg-white/20 transition-all opacity-80">
<p class="text-[10px] font-bold opacity-70 mb-1">YESTERDAY • 6:15 PM</p>
<p class="font-body text-sm line-clamp-2">"Looking for a healthy dinner option under $10"</p>
</div>
<div class="p-4 rounded-xl bg-white/5 border border-white/5 cursor-pointer hover:bg-white/20 transition-all opacity-60">
<p class="text-[10px] font-bold opacity-70 mb-1">TUESDAY • 1:05 PM</p>
<p class="font-body text-sm line-clamp-2">"Is the pasta bar at Canteen 2 open?"</p>
</div>
</div>
<div class="p-8 border-t border-white/20">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-white/20 border border-white/30 flex items-center justify-center">
<span class="material-symbols-outlined text-white">auto_awesome</span>
</div>
<div>
<p class="font-headline font-bold text-sm">AI Concierge</p>
<p class="text-[10px] opacity-70 uppercase tracking-widest">Active session</p>
</div>
</div>
</div>
</div>
</nav>
</aside>
<!-- Main Content Canvas -->
<main class="md:ml-32 pt-28 pb-24 px-6 md:px-12 min-h-screen">
<div class="max-w-5xl mx-auto block" id="content-home">
<header class="hero-header mb-10 text-center md:text-left">
<h2 class="font-headline font-extrabold text-4xl md:text-6xl text-on-surface tracking-tight leading-tight">
                What are we <span class="text-primary">craving</span> today?
            </h2>
<div class="h-1.5 w-24 bg-primary/20 mt-6 rounded-full mx-auto md:mx-0"></div>
</header>
<!-- Chat Container (Hidden initially) -->
<div class="chat-container">
<div class="flex flex-col gap-6 max-w-3xl">
<!-- Message 1 (Transformed Header) -->
<div class="flex gap-4 items-start">
<div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white shrink-0">
<span class="material-symbols-outlined text-sm">auto_awesome</span>
</div>
<div class="bg-white p-6 rounded-3xl rounded-tl-none shadow-sm border border-gray-100 max-w-[85%]">
<p class="font-body text-on-surface leading-relaxed">
                            Welcome back! I'm your CampusBite AI. I can help you find exactly what you're craving. What's on your mind today?
                        </p>
</div>
</div>
<div class="flex gap-4 items-start justify-end">
<div class="bg-primary text-white p-6 rounded-3xl rounded-tr-none shadow-md max-w-[85%]">
<p class="font-body leading-relaxed">I want something spicy near the Library...</p>
</div>
<div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center shrink-0 overflow-hidden">
<img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCyXa7VhjGAgaSrDF4m0zcosGWc6e02Buna51pel2wDasjtvGisB_5S-iSKgZCjVMtbstTOyqKdegp21_stHVha68--f_rRwFrxQ2sxftKLVnuNATBXL_WoESDE5qqPda_TXXy-MnZgm6ol-QTPN7Y7CKDBdjn8vaqk9bYhQSzd6YBgxLhwTWp3fXtQ4b4kimJ4p-pPKWjTV-NVtVq7o4ftm-_SB5LA4GIjnwOPK_GPQ1DnhnpARhNZnBz0CEHSc8rOM2O9l8gbiw"/>
</div>
</div>
<div class="flex gap-4 items-start">
<div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white shrink-0 ai-orb-glow">
<span class="material-symbols-outlined text-sm">auto_awesome</span>
</div>
<div class="bg-white p-6 rounded-3xl rounded-tl-none shadow-sm border border-gray-100 max-w-[85%]">
<p class="font-body text-on-surface leading-relaxed mb-4">
                            Based on your location, I recommend checking out **Window 7** in Canteen 1. Their **Sizzling Black Pepper Chicken** has a nice kick!
                        </p>
<div class="p-4 bg-surface-container-low rounded-2xl border border-primary/10 flex gap-4 items-center">
<img class="w-16 h-16 rounded-lg object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCbW8QPqjXobZido68N5MV69sqvyrjeV6Sf0QT02YkWotFp4XzaFI0V4-BIf-FJSC56H9gc1uyHaOy-Bd-PHybvAPWV-1fhENWfzmlntb2gpjJJ1Q84d8GzuenqpsJumjzgDQNTIEAKihM0rQNmjI1wcNXRpgco9iW718FaLkVOdOEGM1x92Unvtt1I_zkAaOo5cBY3RyoP-QfWj_OrMnhGL2BJHioaXCv2-S7YgRXVkCiJ5sd3tcmrkt7W3mwAjj3foJ7oN7Q1ZQ"/>
<div>
<p class="font-headline font-bold text-sm">Iron Plate Black Pepper Chicken</p>
<p class="text-xs text-on-surface-variant">Canteen 1 • 5 min walk</p>
</div>
</div>
</div>
</div>
</div>
</div>
<!-- AI Search Component -->
<div class="ai-input-wrapper mb-14 max-w-3xl">
<div class="ai-input-glow-wrapper" onclick="toggleAI(true)">
<div class="flex items-center gap-4 bg-white p-2 rounded-full border border-gray-100 relative z-10">
<span class="material-symbols-outlined text-primary ml-6 text-2xl">auto_awesome</span>
<input class="bg-transparent border-none focus:ring-0 flex-grow font-body text-lg placeholder:text-outline py-4" placeholder="I want something spicy near the Library..." type="text"/>
<button class="bg-primary text-on-primary px-8 py-4 rounded-full font-headline font-bold text-sm tracking-wide uppercase transition-all hover:brightness-110 active:scale-95 shadow-md shadow-primary/20">
                        Ask AI
                    </button>
</div>
</div>
</div>
<!-- Recommendation Cards Group -->
<div class="recommendation-cards">
<section class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
<div class="lg:col-span-8 bg-white rounded-[2.5rem] overflow-hidden shadow-xl shadow-gray-200/50 border border-gray-50">
<div class="relative h-72 md:h-[450px] w-full">
<img alt="Close-up of sizzling iron plate black pepper chicken rice" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCbW8QPqjXobZido68N5MV69sqvyrjeV6Sf0QT02YkWotFp4XzaFI0V4-BIf-FJSC56H9gc1uyHaOy-Bd-PHybvAPWV-1fhENWfzmlntb2gpjJJ1Q84d8GzuenqpsJumjzgDQNTIEAKihM0rQNmjI1wcNXRpgco9iW718FaLkVOdOEGM1x92Unvtt1I_zkAaOo5cBY3RyoP-QfWj_OrMnhGL2BJHioaXCv2-S7YgRXVkCiJ5sd3tcmrkt7W3mwAjj3foJ7oN7Q1ZQ"/>
<div class="absolute top-8 left-8 bg-white/95 backdrop-blur-md px-5 py-2.5 rounded-full flex items-center gap-2 shadow-sm">
<span class="material-symbols-outlined text-primary text-lg" style='font-variation-settings: "FILL" 1;'>location_on</span>
<span class="text-xs font-headline font-bold tracking-wider text-on-surface uppercase">Canteen 1, 3rd Floor</span>
</div>
</div>
<div class="p-10 relative">
<div class="flex justify-between items-start mb-8">
<div>
<p class="text-primary font-headline font-bold text-xs uppercase tracking-[0.2em] mb-3">Window 7 Specialty</p>
<h3 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface leading-tight">Iron Plate Black Pepper Chicken Rice</h3>
</div>
<div class="bg-surface-container-low w-16 h-16 rounded-2xl flex items-center justify-center shadow-inner">
<span class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span>
</div>
</div>
<div class="mb-10 pl-8 border-l-4 border-primary-container italic">
<p class="font-body text-xl text-on-surface-variant leading-relaxed">
                                "Every time the half-hour queue is worth it, the chicken is freshly fried."
                            </p>
</div>
<div class="flex flex-wrap gap-3 mb-10">
<span class="px-5 py-2.5 bg-green-50 text-green-700 rounded-full font-headline text-xs font-bold flex items-center gap-2 border border-green-100">
<span class="material-symbols-outlined text-sm">bolt</span> Fast Service
                            </span>
<span class="px-5 py-2.5 bg-yellow-50 text-yellow-700 rounded-full font-headline text-xs font-bold flex items-center gap-2 border border-yellow-100">
<span class="material-symbols-outlined text-sm">expand</span> Large Portion
                            </span>
</div>
</div>
</div>
<div class="lg:col-span-4 flex flex-col gap-8">
<div class="bg-primary p-10 rounded-[2.5rem] flex flex-col items-center text-center shadow-2xl shadow-primary/30">
<div class="w-24 h-24 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center mb-8">
<span class="material-symbols-outlined text-white text-5xl" style='font-variation-settings: "FILL" 1;'>favorite</span>
</div>
<h4 class="font-headline font-extrabold text-white text-2xl mb-8">Found your match?</h4>
<button class="w-full bg-white text-primary py-5 rounded-2xl font-headline font-black text-sm tracking-widest uppercase shadow-xl transition-all hover:scale-[1.02] active:scale-[0.98]">
                            I want to eat
                        </button>
</div>
<div class="bg-white p-8 rounded-[2.5rem] shadow-lg border border-gray-50">
<p class="font-headline font-bold text-[11px] uppercase tracking-[0.2em] text-on-surface-variant mb-6">You might also like</p>
<div class="flex items-center gap-5 p-2 rounded-2xl hover:bg-surface-container-low transition-colors cursor-pointer">
<div class="w-20 h-20 rounded-2xl bg-surface-container-highest overflow-hidden flex-shrink-0 shadow-sm">
<img alt="Salad" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCuZK4awMbiC-__vtatf_8gdoPajdeHcbNwr9PSrGSpdvCsyE0vMWPqcRBAg0wMshANCYcCjrN31wavzqFYvZ31j-SEDKh-VyYN95tqhAboywhv7PB3el1DFfgKb2gewNO9tBgDGitdmTEvF8LNjhue8MNc4XkXjbrFI1cVLCUcxyua85k3yFE3CH8Aq_E61t9BCGKCazbnbKLneSUdFux0WFMkFnPDrHS7U2QeetguFpYAa4d_qQggdurwry0HkAkntJzBcVAknQ"/>
</div>
<div class="min-w-0">
<h5 class="font-headline font-bold text-on-surface text-lg truncate">Avocado Poke Bowl</h5>
<p class="font-body text-sm text-on-surface-variant">Canteen 2, Gym Side</p>
</div>
</div>
</div>
</div>
</section>
</div>
</div>
</main>
<!-- Mobile Bottom Navigation -->
<nav class="md:hidden fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-lg flex justify-around items-center py-4 px-6 z-50 border-t border-gray-100">
<a class="flex flex-col items-center gap-1 text-primary" href="#">
<span class="material-symbols-outlined active-icon">home</span>
<span class="text-[10px] font-headline font-bold uppercase tracking-wider">Home</span>
</a>
<a class="flex flex-col items-center gap-1 text-on-surface-variant" href="#">
<span class="material-symbols-outlined">restaurant</span>
<span class="text-[10px] font-headline font-bold uppercase tracking-wider">Explore</span>
</a>
<div class="mt-[-2.5rem] bg-primary w-16 h-16 rounded-full flex items-center justify-center shadow-xl border-4 border-[#fbfbfb]" onclick="toggleAI(true)">
<span class="material-symbols-outlined text-white text-3xl">auto_awesome</span>
</div>
<a class="flex flex-col items-center gap-1 text-on-surface-variant" href="#" onclick="goToMap()">
<span class="material-symbols-outlined">map</span>
<span class="text-[10px] font-headline font-bold uppercase tracking-wider">Map</span>
</a>
<a class="flex flex-col items-center gap-1 text-on-surface-variant" href="#">
<span class="material-symbols-outlined">bookmark</span>
<span class="text-[10px] font-headline font-bold uppercase tracking-wider">Saved</span>
</a>
<a class="flex flex-col items-center gap-1 text-on-surface-variant" href="#">
<span class="material-symbols-outlined">person</span>
<span class="text-[10px] font-headline font-bold uppercase tracking-wider">Profile</span>
</a>
</nav>
<script>
    function goToMap() {
        window.location.href = '/map';
    }

    function toggleAI(activate) {
        const body = document.body;
        if (activate) {
            body.classList.add('ai-active');
        } else {
            body.classList.remove('ai-active');
            updateIndicator(); // Reset rail indicator
        }
    }

    function updateIndicator() {
        if (document.body.classList.contains('ai-active')) return;

        const activeItem = document.querySelector('.nav-item.active');
        if (!activeItem) return;

        const indicator = document.getElementById('nav-indicator');
        const iconBox = activeItem.querySelector('.icon-box');
        const aside = document.querySelector('aside');

        const asideRect = aside.getBoundingClientRect();
        const iconBoxRect = iconBox.getBoundingClientRect();

        const top = iconBoxRect.top - asideRect.top;
        const left = iconBoxRect.left - asideRect.left;

        indicator.style.top = `${top}px`;
        indicator.style.left = `${left}px`;
        indicator.style.width = `${iconBoxRect.width}px`;
        indicator.style.height = `${iconBoxRect.height}px`;
    }

    function switchTab(tabId, el) {
        if (event) event.preventDefault();
        if (document.body.classList.contains('ai-active')) return;

        document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.remove('active');
            item.querySelector('.label').classList.remove('text-primary');
            item.querySelector('.label').classList.add('text-on-surface-variant');
            const icon = item.querySelector('.material-symbols-outlined');
            icon.classList.remove('active-icon', 'text-primary');
            icon.classList.add('text-on-surface-variant');
        });

        el.classList.add('active');
        el.querySelector('.label').classList.replace('text-on-surface-variant', 'text-primary');
        const icon = el.querySelector('.material-symbols-outlined');
        icon.classList.add('active-icon');
        icon.classList.replace('text-on-surface-variant', 'text-primary');

        updateIndicator();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.addEventListener('load', updateIndicator);
    window.addEventListener('resize', updateIndicator);
</script>
</body></html>
